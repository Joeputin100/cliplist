    <string name="info_alphabetize">Sorts the tracks in each playlist alphabetically. Turn this off to keep the card\'s own file order.</string>
    <string name="info_cover_art">Saves a small album-art image (folder.jpg) into each music folder that doesn\'t already have one, so the player can show artwork.</string>
